# AI Provider API Keys
OPENAI_API_KEY=your_openai_api_key_here
ANTHROPIC_API_KEY=your_anthropic_api_key_here
ELEVENLABS_API_KEY=your_elevenlabs_api_key_here
XAI_API_KEY=your_xai_api_key_here

# Google Cloud Text-to-Speech (Chirp HD) — unlike the keys above, this is a path to a
# service-account JSON key file, not a bare API key. Create one in Google Cloud Console
# under IAM & Admin > Service Accounts, grant it the "Cloud Text-to-Speech User" role,
# download its JSON key, and point this at the file's path.
GOOGLE_APPLICATION_CREDENTIALS=/path/to/service-account.json

# Application Configuration
DATA_DIR=./data
AUDIO_DIR=./audio
SCRIPTS_DIR=./scripts
EMBEDDINGS_DIR=./embeddings

# Default Settings
DEFAULT_VOICE_PROVIDER=elevenlabs
DEFAULT_EMBEDDING_MODEL=text-embedding-3-small
DEFAULT_CHUNK_SIZE=1000
DEFAULT_CHUNK_OVERLAP=200

